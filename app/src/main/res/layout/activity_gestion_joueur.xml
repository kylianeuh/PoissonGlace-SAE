<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A4E2FC">

    <include
        layout="@layout/fond_complet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.sae402.poissonglobe.PoissonGlaceTextView
        android:id="@+id/txtTitre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Poisson Glace"
        android:fontFamily="@font/cherry_bomb"
        android:textColor="#FFD700"
        android:textSize="54sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.sae402.poissonglobe.PoissonGlaceTextView
        android:id="@+id/btnRetourDetails"
        android:layout_width="120dp"
        android:layout_height="60dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bouton_arrondi_bordure"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="@font/cherry_bomb"
        android:gravity="center"
        android:text="Retour"
        android:textColor="#FFD700"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@+id/btnCommencer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtTitre" />

    <!-- BOUTON COMMENCER -->
    <com.sae402.poissonglobe.PoissonGlaceTextView
        android:id="@+id/btnCommencer"
        android:layout_width="180dp"
        android:layout_height="60dp"
        android:layout_marginStart="764dp"
        android:layout_marginTop="464dp"
        android:background="@drawable/bouton_arrondi_bordure"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="@font/cherry_bomb"
        android:gravity="center"
        android:text="Commencer"
        android:textColor="#FFD700"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>