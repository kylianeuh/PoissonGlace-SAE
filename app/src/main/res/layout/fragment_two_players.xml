<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- LIGNE J1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical">

        <com.sae402.poissonglobe.PoissonGlaceTextView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bouton_rond_bordure"
            android:fontFamily="@font/cherry_bomb"
            android:gravity="center"
            android:text="J1"
            android:paddingBottom="4dp"
            android:textAlignment="center"
            android:textColor="#FFD700"
            android:textSize="22sp" />

        <Spinner
            android:id="@+id/spinnerJ1"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginHorizontal="16dp"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:background="@drawable/bouton_arrondi_bordure"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:dropDownWidth="match_parent"
            android:dropDownVerticalOffset="44dp"
            android:dropDownSelector="@android:color/transparent"
            android:popupBackground="#22A7F0" />

        <com.sae402.poissonglobe.PoissonGlaceTextView
            android:id="@+id/btnAddJ1"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bouton_rond_bordure"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/cherry_bomb"
            android:text="+"
            android:paddingTop="4dp"
            android:textAlignment="center"
            android:textColor="#FFD700"
            android:textSize="30sp" />
    </LinearLayout>

    <!-- LIGNE J2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.sae402.poissonglobe.PoissonGlaceTextView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bouton_rond_bordure"
            android:gravity="center"
            android:text="J2"
            android:paddingBottom="4dp"
            android:textSize="22sp"
            android:fontFamily="@font/cherry_bomb"
            android:textColor="#FFD700" />

        <Spinner
            android:id="@+id/spinnerJ2"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginHorizontal="16dp"
            android:layout_weight="1"
            android:background="@drawable/bouton_arrondi_bordure"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:dropDownWidth="match_parent"
            android:dropDownVerticalOffset="44dp"
            android:dropDownSelector="@android:color/transparent"
            android:popupBackground="@drawable/bouton_arrondi_bordure" />

        <com.sae402.poissonglobe.PoissonGlaceTextView
            android:id="@+id/btnAddJ2"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bouton_rond_bordure"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/cherry_bomb"
            android:text="+"
            android:paddingTop="4dp"
            android:textAlignment="center"
            android:textColor="#FFD700"
            android:textSize="30sp" />
    </LinearLayout>
</LinearLayout>