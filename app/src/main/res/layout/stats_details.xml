<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false">

    <include layout="@layout/fond_complet" />

    <com.sae402.poissonglobe.PoissonGlaceTextView
        android:id="@+id/btnRetourDetails"
        android:layout_width="120dp"
        android:layout_height="60dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bouton_arrondi_bordure"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="@font/cherry_bomb"
        android:gravity="center"
        android:text="Retour"
        android:textColor="#FFD700"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.sae402.poissonglobe.PoissonGlaceTextView
        android:id="@+id/txtNomJoueur"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:fontFamily="@font/cherry_bomb"
        android:text="STATISTIQUES"
        android:textColor="#FFD700"
        android:textSize="44sp"
        android:textStyle="bold"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/colonneGauche"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bouton_arrondi_bordure"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintHorizontal_weight="30"
        app:layout_constraintTop_toBottomOf="@id/txtNomJoueur"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/colonneCentre">

        <com.sae402.poissonglobe.PoissonGlaceTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/cherry_bomb"
            android:text="Dernières parties"
            android:textColor="#FFFFFF"
            android:textSize="22sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDernieresParties"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/colonneCentre"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bouton_arrondi_bordure"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintHorizontal_weight="40"
        app:layout_constraintTop_toBottomOf="@id/txtNomJoueur"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/colonneGauche"
        app:layout_constraintEnd_toStartOf="@id/zoneClassement">

        <com.sae402.poissonglobe.PoissonGlaceTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"
            android:fontFamily="@font/cherry_bomb"
            android:text="Statistiques globales"
            android:textColor="#FFFFFF"
            android:textSize="22sp" />

        <com.sae402.poissonglobe.PoissonGlaceTextView
            android:id="@+id/txtPartiesJouees"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:fontFamily="@font/cherry_bomb"
            android:text="Nombre de parties jouées : 0"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <com.sae402.poissonglobe.PoissonGlaceTextView
            android:id="@+id/txtPartiesGagnees"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:fontFamily="@font/cherry_bomb"
            android:text="Nombre de parties gagnées : 0"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <com.sae402.poissonglobe.PoissonGlaceTextView
            android:id="@+id/txtPointsTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/cherry_bomb"
            android:text="Nombre de points au total : 0"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/zoneClassement"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bouton_arrondi_bordure"

        app:layout_constraintHorizontal_weight="30"

        app:layout_constraintTop_toBottomOf="@id/txtNomJoueur"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/colonneCentre"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>